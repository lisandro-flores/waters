# Variables de entorno para desarrollo local
# Copiar a .env y ajustar según el entorno

# ──────── Base de datos ────────
DB_HOST=localhost
DB_PORT=5433
DB_NAME=agua_potable
DB_USER=postgres
DB_PASS=postgres

# ──────── JWT ────────
JWT_SECRET=dev-secret-key-para-desarrollo-local-32chars!!

# ──────── Node env ────────
NODE_ENV=development

# ──────── Puertos ────────
PORT=8081
FRONTEND_PORT=4200
