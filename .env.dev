# Variables de entorno para desarrollo local
# Copiar a .env y ajustar según el entorno

# ──────── Base de datos ────────
DB_HOST=localhost
DB_PORT=5433
DB_NAME=agua_potable
DB_USER=postgres
DB_PASS=postgres

# Full JDBC URL (para referencia)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/agua_potable

# ──────── JWT ────────
JWT_SECRET=dev-secret-key-para-desarrollo-local-32chars!!

# ──────── Spring profile ────────
SPRING_PROFILES_ACTIVE=dev

# ──────── Puertos ────────
BACKEND_PORT=8081
FRONTEND_PORT=4200
